{
    "name": "victory-sokolov-blog",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "author": {
        "name": "Viktor Sokolov"
    },
    "license": "MIT",
    "engines": {
        "bun": ">= 1.2.4",
        "npm": "please use bun",
        "yarn": "please use bun",
        "node": ">=24.0.0"
    },
    "scripts": {
        "dev": "bun --bun next dev --experimental-https",
        "build": "bun --bun next build",
        "start": "bun --bun next start",
        "analyze": "ANALYZE=true bun run build",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "lint:mdx": "bun eslint content/**/*.mdx",
        "lint:style": "stylelint '**/*.css'",
        "lint:style:fix": "stylelint '**/*.css' --fix",
        "fix": "bun run lint:fix && bun run lint:style:fix",
        "typecheck": "tsc --noEmit --pretty",
        "install:prod": "bun install --frozen-lockfile --production",
        "commit": "cz",
        "prepare": "husky || true",
        "format": "prettier --config ./.prettierrc src/**/*.{ts,tsx} --write",
        "format:check": "prettier --config ./.prettierrc src/**/*.{ts,tsx}",
        "prebuild": "bun run generate",
        "generate": "npm-run-all generate:**",
        "generate:copyimages": "tsx ./lib/copy-images.ts",
        "generate:feed": "tsx ./lib/generate-feed.ts",
        "generate:validate": "tsx ./lib/validate-content.ts",
        "fetch-tips": "tsx --env-file .env ./lib/twitter-tips.mts",
        "spell-check": "spellchecker --config .spellcheckerrc.json",
        "knip": "knip",
        "knip:fix": "knip --fix",
        "up": "bun update --interactive"
    },
    "dependencies": {
        "@lhci/cli": "0.15.1",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "@vsokolov/utils": "1.4.2",
        "axios": "^1.13.6",
        "file-type": "^22.0.1",
        "gray-matter": "^4.0.3",
        "next": "^16.2.4",
        "next-mdx-remote": "^6.0.0",
        "next-pwa": "^5.6.0",
        "next-seo": "^7.0.1",
        "prism-react-renderer": "^2.4.1",
        "prismjs": "^1.30.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-icons": "^5.6.0",
        "react-wrap-balancer": "1.1.1",
        "rehype-slug": "^6.0.0",
        "remark": "^15.0.1",
        "remark-code-titles": "^0.1.2",
        "remark-html": "^16.0.1",
        "sharp": "^0.34.5",
        "tailwindcss": "4.2.4",
        "twitter-api-v2": "^1.29.0",
        "xml2json": "0.12.0"
    },
    "devDependencies": {
        "@antfu/eslint-config": "8.2.0",
        "@dreamsicle.io/stylelint-config-tailwindcss": "1.2.2",
        "@eslint/eslintrc": "^3.3.5",
        "@next/bundle-analyzer": "^16.2.4",
        "@tailwindcss/postcss": "4.2.4",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/next-pwa": "^5.6.9",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/xml2json": "^0.11.6",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "commitizen": "^4.3.1",
        "eslint": "^10.3.0",
        "eslint-config-next": "^16.2.4",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-mdx": "^3.7.0",
        "eslint-plugin-no-floating-promise": "^2.0.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "feed": "^5.2.1",
        "husky": "^9.1.7",
        "knip": "^6.11.0",
        "lint-staged": "^16.4.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.3",
        "spellchecker-cli": "7.0.3",
        "stylelint": "17.11.0",
        "stylelint-config-standard": "40.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "webpack": "5.104.1",
        "xml2js": "0.6.2"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        },
        "lint-staged": {
            "*": "bun run lint:fix"
        }
    }
}
